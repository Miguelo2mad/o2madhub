# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google OAuth2 (Gmail + Drive) — see docs/gmail-oauth2-setup.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Notifications
NOTIFY_TO=sandra@o2mad.com,pedro@agesbal.com
NOTIFY_CC=info@o2mad.com

# Gmail search for new invoices (last 24h)
FACTURA_QUERY=newer_than:1d (factura OR invoice OR recibo OR receipt OR fra)

# Drive root folder id (set automatically by: node setup-drive.js)
DRIVE_ROOT_FOLDER_ID=

# HTTP server port
PORT=8080
