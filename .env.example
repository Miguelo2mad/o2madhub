# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Google OAuth2 (Gmail + Drive) — see docs/gmail-oauth2-setup.md
# Primary account (o2mktmiguel@gmail.com). CLIENT_ID/SECRET are shared by all Gmail accounts.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_USER=

# Multi-account: additional Gmail accounts (mint with: node get-token.js --account=apper)
ACCT_APPER_GOOGLE_REFRESH_TOKEN=

# Outlook / Microsoft 365 (Gulliver Ventures) — app-only Microsoft Graph access.
# Entra ID → App registration with Graph application permission Mail.Read (admin-consented).
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_GULLIVER_EMAIL=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Notifications
NOTIFY_TO=sandra@o2mad.com,pedro@agesbal.com
NOTIFY_CC=info@o2mad.com

# Gmail search for new invoices (last 24h)
FACTURA_QUERY=newer_than:1d (factura OR invoice OR recibo OR receipt OR fra)

# Known invoice senders whose mail is captured even without factura keywords
# (also catches Re:/Fwd: threads with PDF attachments). Comma-separated.
INVOICE_SENDERS=bielsb@bsbadministracio.es,sandra@o2mad.com

# Drive root folder id (set automatically by: node setup-drive.js)
DRIVE_ROOT_FOLDER_ID=

# Sandra's invoice archive folder (scanned by backend/agents/drive-scan-agent.js)
DRIVE_INVOICES_FOLDER_ID=

# HTTP server port
PORT=8080
